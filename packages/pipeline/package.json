{
  "name": "@async/pipeline",
  "version": "0.7.0",
  "description": "Local-first TypeScript pipelines with one task graph for laptops and CI.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "directory": "packages/pipeline",
    "type": "git",
    "url": "git+https://github.com/async/pipeline.git"
  },
  "bugs": {
    "url": "https://github.com/async/pipeline/issues"
  },
  "homepage": "https://github.com/async/pipeline#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./lima": {
      "types": "./dist/lima.d.ts",
      "default": "./dist/lima.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    }
  },
  "bin": {
    "async-pipeline": "./dist/cli.js"
  },
  "scripts": {
    "build": "pnpm --filter @async/pipeline-core build && pnpm --filter @async/pipeline-node build && pnpm --filter @async/pipeline-adapter-lima build && tsc -p tsconfig.build.json && node scripts/bundle-internals.js && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "pack:check": "npm --cache ../../.async/npm-cache pack --dry-run"
  },
  "files": [
    "API_SURFACE.md",
    "api-contract.json",
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  }
}
